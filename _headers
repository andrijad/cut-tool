# Cloudflare Pages security headers — applied to all routes
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://cuttool.app; connect-src 'none'; frame-ancestors 'none'
  Cache-Control: public, max-age=3600

# Cache static assets longer
/og/*
  Cache-Control: public, max-age=2592000, immutable

/sitemap.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml; charset=UTF-8

/sitemap.xsl
  Cache-Control: public, max-age=86400
  Content-Type: text/xsl; charset=UTF-8

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/robots.txt
  Cache-Control: public, max-age=86400
